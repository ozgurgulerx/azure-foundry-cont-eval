# Azure AI Foundry Continuous Evaluation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_REGION=

# --- Azure AI Foundry ---
AZURE_AI_PROJECT_NAME=
AZURE_AI_PROJECT_CONNECTION_STRING=

# --- Azure AI Services / Model Deployment ---
AZURE_AI_SERVICES_ENDPOINT=
AZURE_MODEL_DEPLOYMENT_NAME=gpt-4o

# --- Application Insights ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_RESOURCE_ID=

# --- Agent ---
AZURE_AGENT_NAME=cont-eval-test-agent

# --- Evaluation ---
EVALUATION_SCHEDULE_NAME=cont-eval-schedule

# --- Authentication ---
# Uses DefaultAzureCredential by default. Set these only if needed.
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=
