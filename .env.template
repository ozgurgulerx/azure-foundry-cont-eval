# Azure AI Foundry Continuous Evaluation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Azure Subscription ---
AZURE_SUBSCRIPTION_ID=
AZURE_RESOURCE_GROUP=
AZURE_REGION=

# --- Azure AI Foundry ---
# Must be a Foundry project (NOT hub-based).
# Find at: Foundry portal → Project → Overview → Project endpoint
AZURE_AI_PROJECT_ENDPOINT=

# --- Model Deployment ---
AZURE_MODEL_DEPLOYMENT_NAME=gpt-4o

# --- Application Insights ---
APPLICATIONINSIGHTS_CONNECTION_STRING=
APPINSIGHTS_RESOURCE_ID=

# --- Log Analytics (for Kusto queries in verification) ---
LOGS_WORKSPACE_ID=

# --- Agent ---
AZURE_AI_AGENT_NAME=cont-eval-test-agent

# --- Authentication ---
# Uses DefaultAzureCredential by default (az login).
# Set these only for service principal auth:
# AZURE_CLIENT_ID=
# AZURE_TENANT_ID=
# AZURE_CLIENT_SECRET=
